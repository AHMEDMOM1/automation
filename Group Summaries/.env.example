# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=first_chat_id,second_chat_id

# ─── WhatsApp — Selenium (WhatsApp Web) ─────────────────────
WHATSAPP_SOURCE=selenium

# Browser profile directory (keeps QR login between runs)
SELENIUM_PROFILE_DIR=selenium-profile
SELENIUM_INITIAL_WAIT=15
SELENIUM_CHAT_WAIT=4
LAST_N_MESSAGES=50

# ─── WhatsApp Group Names (JSON array) ──────────────────────
# Exact names as they appear in WhatsApp
WHATSAPP_GROUP_NAMES=["Group Name 1","Group Name 2"]

# ─── Filter Keywords (JSON array) ───────────────────────────
FILTER_KEYWORDS=["keyword1","keyword2"]

# ─── WhatsApp Group Mapping (JSON, optional) ────────────────
WHATSAPP_GROUP_MAP={}

# ─── OpenRouter (LLM for Summarization) ─────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ─── Digest Settings ───────────────────────────────────────
DIGEST_STATE_STORE=.tmp/state.json
SEND_EMPTY_GROUPS=false
MAX_MESSAGES_PER_GROUP=500
DEFAULT_TIME_WINDOW=24h
